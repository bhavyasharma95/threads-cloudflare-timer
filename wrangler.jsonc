{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "threads-timer",
	"main": "src/index.js",
	"compatibility_date": "2026-05-09",
	"observability": {
		"enabled": true,
	},
	"upload_source_maps": true,
	"compatibility_flags": ["nodejs_compat"],
	"triggers": {
		"crons": ["* * * * *", "*/45 * * * *"],
	},
}
